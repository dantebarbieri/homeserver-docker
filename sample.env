# ==============================================================================
# Common - shared across most services
# ==============================================================================
UID=1000
GID=1000
TZ=America/Chicago
DATA=/srv/docker/data
RAID=/data

# ==============================================================================
# Authelia - secrets are managed as files, not env vars.
# See ${DATA}/authelia/secrets/ and compose.auth.yml for details.
# ==============================================================================

# ==============================================================================
# Immich - https://immich.app/docs/install/environment-variables
# ==============================================================================
UPLOAD_LOCATION=/data/immich
IMMICH_VERSION=release
DB_PASSWORD=
# Immich internal defaults (rarely need changing)
DB_HOSTNAME=immich_postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
REDIS_HOSTNAME=immich_redis

# ==============================================================================
# Plex
# ==============================================================================
# https://www.plex.tv/claim/
PLEX_CLAIM=claim-xxxxxx
ADVERTISE_IP=http://<hostIPAddress>:32400/

# ==============================================================================
# Gluetun / qBittorrent (VPN + torrents)
# ==============================================================================
WG_PRIVATE_KEY=
WG_ADDRESS=
SERVER_COUNTRY="United States"
SERVER_CITIES=Austin,Dallas,Houston
QUSER=
QPASS=

# ==============================================================================
# Suwayomi (manga reader + Postgres)
# ==============================================================================
SUWAYOMI_USER=suwayomi
SUWAYOMI_PASS=
SUWAYOMI_DB=suwayomi_db

# ==============================================================================
# Matrix / Synapse / LiveKit
# ==============================================================================
SYNAPSE_SERVER_NAME=example.com
SYNAPSE_DB_PASSWORD=
# Shared secret between Synapse and Coturn for TURN auth.
# Must also be set in turnserver.conf and homeserver.yaml (see MATRIX.md).
COTURN_AUTH_SECRET=
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=

# ==============================================================================
# Homepage - service widget API keys/credentials
# Obtain keys from each service's settings page.
# ==============================================================================
HOMEPAGE_VAR_PLEX_TOKEN=
HOMEPAGE_VAR_JELLYFIN_KEY=
HOMEPAGE_VAR_OVERSEERR_KEY=
HOMEPAGE_VAR_IMMICH_KEY=
HOMEPAGE_VAR_KOMGA_USER=
HOMEPAGE_VAR_KOMGA_PASS=
HOMEPAGE_VAR_RADARR_KEY=
HOMEPAGE_VAR_SONARR_KEY=
HOMEPAGE_VAR_BAZARR_KEY=
HOMEPAGE_VAR_PROWLARR_KEY=
HOMEPAGE_VAR_SABNZBD_KEY=
HOMEPAGE_VAR_NPM_USER=
HOMEPAGE_VAR_NPM_PASS=

# ==============================================================================
# SearXNG
# ==============================================================================
SEARXNG_HOSTNAME=

# ==============================================================================
# Tdarr
# ==============================================================================
TDARR_API_KEY=

# ==============================================================================
# Gaming (Minecraft)
# ==============================================================================
CF_API_KEY=

